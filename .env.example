# ─── Telegram ──────────────────────────────────────────────────────────────────
# Get this from @BotFather on Telegram
BOT_TOKEN=your_telegram_bot_token_here

# ─── Server ─────────────────────────────────────────────────────────────────────
# Railway sets PORT automatically — only set this locally
PORT=3000

# ─── Database ───────────────────────────────────────────────────────────────────
# Path where db.json is stored. On Railway use /data/db.json for persistence.
DB_PATH=./data/db.json
